<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mac Server Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/ipEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IP Address (e.g., 192.168.1.5)"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />
            
        <EditText
            android:id="@+id/portEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Port (default: 8766)"
            android:inputType="number"
            android:text="8766"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:background="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manual Sync"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/sendClipboardButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Clipboard to Mac"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/manualEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Or type/paste text here..."
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top|start"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/sendTextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Typed Text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Tip: You can also use the 'Share' menu in most apps or the text selection popup to send text/images directly."
            android:gravity="center"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
